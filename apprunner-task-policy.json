{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3Access",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::cndd-publica",
        "arn:aws:s3:::cndd-publica/*",
        "arn:aws:s3:::cndd-proyectos",
        "arn:aws:s3:::cndd-proyectos/*",
        "arn:aws:s3:::cndd-rrhh",
        "arn:aws:s3:::cndd-rrhh/*",
        "arn:aws:s3:::cndd-logs",
        "arn:aws:s3:::cndd-logs/*"
      ]
    },
    {
      "Sid": "CognitoAccess",
      "Effect": "Allow",
      "Action": [
        "cognito-idp:*"
      ],
      "Resource": "arn:aws:cognito-idp:us-east-2:430374710014:userpool/us-east-2_K7P0oSbDg"
    },
    {
      "Sid": "OpenSearchAccess",
      "Effect": "Allow",
      "Action": [
        "es:*"
      ],
      "Resource": "arn:aws:es:us-east-2:430374710014:domain/cndd-opensearch/*"
    },
    {
      "Sid": "SecretsManagerAccess",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue"
      ],
      "Resource": "arn:aws:secretsmanager:us-east-2:430374710014:secret:cndd-project/production-*"
    },
    {
      "Sid": "CloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:us-east-2:430374710014:log-group:/aws/apprunner/*"
    }
  ]
}